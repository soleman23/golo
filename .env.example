# Supabase project credentials (Project Settings -> API).
# Copy this file to .env.local and fill in your project's values.
# The anon key is a public, RLS-protected key and is safe to ship in the client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push (Phase 3) — the VAPID *public* key only (safe to ship in the client).
# Generate a keypair with `node scripts/gen-vapid.mjs`; keep the private key as a
# Supabase secret for the send-push Edge Function. Leave blank to disable push.
VITE_VAPID_PUBLIC_KEY=
