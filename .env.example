# Supabase project credentials (Project Settings -> API).
# Copy this file to .env.local and fill in your project's values.
# The anon key is a public, RLS-protected key and is safe to ship in the client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side maintenance scripts only. Never expose this as a VITE_* variable.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
